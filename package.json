{
  "name": "resume-analyzer",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @resume-analyzer/api --filter @resume-analyzer/web dev",
    "dev:api": "corepack pnpm --filter @resume-analyzer/api dev",
    "dev:web": "corepack pnpm --filter @resume-analyzer/web dev",
    "build:api": "corepack pnpm --filter @resume-analyzer/api build",
    "build:web": "corepack pnpm --filter @resume-analyzer/web build",
    "typecheck": "corepack pnpm -r typecheck"
  }
}

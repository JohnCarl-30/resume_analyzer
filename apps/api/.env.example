PORT=4000
APP_ORIGIN=http://localhost:3000

# Postgres (Supabase connection string). Omit for in-memory storage.
DATABASE_URL=postgres://postgres:password@db.your-project.supabase.co:5432/postgres

# Supabase (required for auth in production)
SUPABASE_URL=https://your-project.supabase.co

# AI — OpenAI (required for full AI features)
OPENAI_API_KEY=sk-...
AI_EXTRACTION_MODEL=gpt-4o-mini

# Cloudflare R2 (required for real resume uploads in production)
R2_BUCKET_NAME=resume-analyzer
R2_PUBLIC_BASE_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

PORT=4000
APP_ORIGIN=http://localhost:3000
# When Next.js falls back to :3001 locally, the API still accepts Clerk tokens from both ports.

# Postgres (Neon or any Postgres). Omit for in-memory storage.
DATABASE_URL=postgres://user:password@host/database

# Clerk (required for authenticated API routes in production)
# Must match CLERK_SECRET_KEY in apps/web/.env.local (same Clerk application).
CLERK_SECRET_KEY=sk_test_...

# AI — OpenAI (required for full AI features)
OPENAI_API_KEY=sk-...
AI_EXTRACTION_MODEL=gpt-4o-mini

# Cloudflare R2 (required for real resume uploads in production)
R2_BUCKET_NAME=resume-analyzer
R2_PUBLIC_BASE_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
